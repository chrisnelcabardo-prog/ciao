```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Special Invitation ❤️</title>

<style>
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:linear-gradient(135deg,#ffd6e0,#ffeef5);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.card{
    background:white;
    width:90%;
    max-width:500px;
    padding:30px;
    border-radius:20px;
    box-shadow:0 10px 25px rgba(0,0,0,.15);
}

img{
    width:250px;
    max-width:100%;
    border-radius:20px;
    margin-bottom:15px;
}

h1{
    color:#ff4d6d;
}

button{
    border:none;
    border-radius:12px;
    padding:12px 24px;
    margin:8px;
    font-size:18px;
    cursor:pointer;
}

.yes{
    background:#4CAF50;
    color:white;
}

.no{
    background:#f44336;
    color:white;
}

input[type="date"]{
    padding:10px;
    font-size:16px;
    border-radius:10px;
}
</style>
</head>

<body>

<div class="card" id="card">

    <h1>Hi Jaymee 😊</h1>

    <img src="cat1.webp" alt="Cute Cat">

    <p>
        I made something for you ❤️
    </p>

    <button class="yes" onclick="start()">
        Continue
    </button>

</div>

<script>

function start(){

    document.getElementById("card").innerHTML = `
        <h1>
        Would you like to hang out with me after class,
        or on a day that works best for you? 😊❤️
        </h1>

        <img src="cat2.gif" alt="Cute Cat">

        <button class="yes" onclick="showDatePicker()">
            Yes ❤️
        </button>

        <button class="no" onclick="confirmNo()">
            No 😔
        </button>
    `;
}

function confirmNo(){

    document.getElementById("card").innerHTML = `
        <h1>Are you sure? 🥺</h1>

        <img src="cat3.webp" alt="Sad Cat">

        <p>
        Think carefully before making the cats sad.
        </p>

        <button class="no" onclick="showSadCat()">
            Yes, I'm sure 😔
        </button>

        <button class="yes" onclick="start()">
            No, wait 🥺
        </button>
    `;
}

function showSadCat(){

    document.getElementById("card").innerHTML = `
        <h1>The cat is sad now 😿</h1>

        <img src="cat4.webp" alt="Very Sad Cat">

        <p>
        The cats were hoping you'd say yes.
        </p>

        <p>
        But thank you for being honest ❤️
        </p>
    `;
}

function showDatePicker(){

    document.getElementById("card").innerHTML = `
        <h1>Yay! 🎉</h1>

        <img src="cat5.gif" alt="Happy Cat">

        <p>
        You just made my day ❤️
        </p>

        <p>
        When would you like us to hang out? 😊
        </p>

        <input type="date" id="datePicker">

        <br><br>

        <button class="yes" onclick="confirmDate()">
            Choose This Date ❤️
        </button>
    `;
}

function confirmDate(){

    const selectedDate =
        document.getElementById("datePicker").value;

    if(!selectedDate){
        alert("Please choose a date first 😊");
        return;
    }

    document.getElementById("card").innerHTML = `
        <h1>Thank You ❤️</h1>

        <p>
        Date selected:
        <strong>${selectedDate}</strong>
        </p>

        <p>
        Looking forward to seeing you 😊
        </p>
    `;
}

</script>

</body>
</html>
```
